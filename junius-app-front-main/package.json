    "framer-motion": "^10.18.0",
    "highlight.js": "^11.10.0",
    "husky": "^9.1.6",
    "i18next": "^23.15.1",
    "i18next-browser-languagedetector": "^7.2.1",
    "lint-staged": "^15.2.10",
    "lodash": "^4.17.21",
    "mapbox-gl": "^3.6.0",
