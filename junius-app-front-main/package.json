{
  "name": "junius-app",
  "author": "Junius App Team",
  "version": "0.2.0",
  "type": "module",
  "description": "A collaborative platform connecting developers, project ideas, and investors",
  "private": true,
  "engines": {
    "node": ">=18.17.1",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:export": "eslint --format html \"src/**/*.{js,jsx,ts,tsx}\" > eslint-results.html",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"  --log-level silent",
    "prepare": "husky",
    "commit": "git add -A && cz",
    "commit:stage": "cz",
    "rm:all": "rm -rf node_modules .next out dist build",
    "re:start": "bun rm:all && bun install && bun dev",
    "re:build": "bun rm:all && bun install && bun build",
    "fix": "bun lint:fix && bun format && bun run tsc"
  },
  "dependencies": {
    "@casl/ability": "^6.7.1",
    "@casl/react": "^4.0.0",
