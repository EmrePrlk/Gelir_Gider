# Django
ENV_NAME=dev
SECRET_KEY=django-insecure-change-me-in-production
INSTANCE_IP=localhost,127.0.0.1

# Storage: FALSE = local filesystem, TRUE = AWS S3
USE_S3=FALSE

# PostgreSQL (sadece prod.py settings kullanılırken gerekli)
# SQL_DATABASE=juniusapp
# SQL_USER=postgres
# SQL_PASSWORD=
# SQL_HOST=localhost
# SQL_PORT=5432

# AWS S3 (USE_S3=TRUE olduğunda gerekli)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_PRIVATE_BUCKET_NAME=
# AWS_S3_CUSTOM_DOMAIN=

# Email (şu an devre dışı)
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Frontend URL (email doğrulama aktif edilirse gerekli)
# FRONTEND_URL=localhost:3000
