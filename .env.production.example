# ── Genel ──────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── Backend (Django) ────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-minimum-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgresql://dashboard:change-this-strong-password@db:5432/dashboard

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL: tarayıcıdan gelen istekler için (nginx proxy üzerinden)
NEXT_PUBLIC_API_URL=https://yourdomain.com
# INTERNAL_API_URL: docker-compose.prod.yml'de sabit, .env'de değiştirme
# INTERNAL_API_URL=http://backend:8000
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your-very-long-random-nextauth-secret-minimum-32-chars
